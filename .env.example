# ─────────────────────────────────────────────────────────────────────────────
# Nexvelon — environment variables
# Copy this file to `.env.local` and fill in real values.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser bundle —
# never put secrets there.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────

# Public, browser-readable. The canonical URL the app is served from. Used by
# OG cards, OAuth redirects, and email link generation. Vercel sets this for
# you on production deploys.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Short build identifier shown in the app footer / about dialogs.
# Vercel exposes this as VERCEL_GIT_COMMIT_SHA — feel free to wire it through.
NEXT_PUBLIC_BUILD_SHA=local

# ── Supabase (auth + Postgres + storage) ────────────────────────────────────
# Three clients are wired up at lib/supabase/{client,server,admin}.ts.

# The project URL — public, browser-readable.
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (anon) key — public, browser-readable. Reads/writes are
# constrained by Row-Level Security policies on the database.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret (service-role) key — SERVER-ONLY. Bypasses RLS. Never commit,
# never expose to the browser. Used by lib/supabase/admin.ts only.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used for verifying server-issued auth tokens (optional).
SUPABASE_JWT_SECRET=

# ── Stripe (planned billing) ─────────────────────────────────────────────────

# Publishable key — browser-safe. Used for Stripe.js + Checkout client SDK.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret key — server-only. Creates Checkout Sessions, Customers, etc.
STRIPE_SECRET_KEY=

# Webhook signing secret used to verify events from Stripe.
STRIPE_WEBHOOK_SECRET=

# ── Twilio (planned SMS notifications) ───────────────────────────────────────

# Server-only credentials for the Twilio REST API.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Sender number in E.164 format, e.g. +14165551212.
TWILIO_FROM_NUMBER=

# ── Resend (transactional email — used by auth OTP) ─────────────────────────
# Server-only API key from https://resend.com/api-keys.
# Must have "Send" access for the verified domain (nexvelonglobal.com).
# Same key may be reused across the Supabase Custom SMTP integration and
# our own direct calls in lib/auth/email.ts.
RESEND_API_KEY=

# Verified sender for outbound mail. Domain must be DKIM/SPF-verified at
# Resend. Used as the From: header on every email this app sends directly
# (the OTP email; everything else is sent by Supabase Auth on our behalf).
RESEND_FROM_EMAIL=Nexvelon <noreply@nexvelonglobal.com>

# ── SendGrid (legacy — not used; kept for reference) ────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=ops@nexvelon.com

# ── QuickBooks Online (planned accounting sync) ──────────────────────────────

# OAuth credentials issued by Intuit. Client ID is browser-readable; secret
# stays on the server.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=

# ── Xero (planned alternative accounting sync) ───────────────────────────────

XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=

# ── Microsoft 365 / Google SSO (planned) ─────────────────────────────────────

# Azure AD application credentials for "Sign in with Microsoft".
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Google OAuth credentials for "Sign in with Google".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SAML SSO (planned, for enterprise self-serve) ────────────────────────────

SAML_IDP_ENTRY_POINT=
SAML_IDP_CERT=
SAML_SP_ACS_URL=

# ── Storage (planned, for Documents tab + branding uploads) ─────────────────

# When the project moves off mock data, files go to S3 / Supabase Storage.
S3_REGION=ca-central-1
S3_BUCKET=nexvelon-prod-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Sentry (planned error tracking) ──────────────────────────────────────────

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Feature flags ────────────────────────────────────────────────────────────

# Toggle the role-switcher visibility. In production this should be `false`.
NEXT_PUBLIC_ENABLE_ROLE_SWITCHER=true

# Toggle the demo-account chips on /login. Production: `false`.
NEXT_PUBLIC_ENABLE_DEMO_ACCOUNTS=true
